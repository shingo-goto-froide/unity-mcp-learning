--- !u!114 &2129437897
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2129437895}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u3010\u76EE\u7684\u3011\n\u76F8\u624B\u306EHP\u30920\u306B\u3059\u308B\u3068\u52DD\u5229\uFF08\u521D\u671FHP:
    15\uFF09\n\n\u30101\u30BF\u30FC\u30F3\u306E\u6D41\u308C\u3011\n\u2460 \u7372\u5F97\u30D5\u30A7\u30FC\u30BA\uFF1A3\u3064\u306E\u30D7\u30FC\u30EB\u304B\u3089\u3072\u3068\u3064\u9078\u3093\u3067\u30EA\u30BD\u30FC\u30B9\u3092\u53D7\u3051\u53D6\u308B\n\u2461
    \u914D\u7F6E\u30D5\u30A7\u30FC\u30BA\uFF1A\u30EA\u30BD\u30FC\u30B9\u3092\u30B9\u30ED\u30C3\u30C8\u306B\u914D\u7F6E\uFF08\u76F8\u624B\u306B\u306F\u898B\u3048\u306A\u3044\uFF09\n\u2462
    \u89E3\u6C7A\u30D5\u30A7\u30FC\u30BA\uFF1A\u5B8C\u6210\u3057\u305F\u884C\u306E\u52B9\u679C\u3092\u4E0A\u304B\u3089\u9806\u306B\u767A\u52D5\n\n\u3010\u30EA\u30BD\u30FC\u30B9\u306E\u52B9\u679C\u3011\nATK\uFF08\u8D64\uFF09\uFF1A\u30C0\u30E1\u30FC\u30B8\u3092\u4E0E\u3048\u308B\nDEF\uFF08\u9752\uFF09\uFF1A\u30B7\u30FC\u30EB\u30C9\u3092\u4ED8\u4E0E\uFF08\u653B\u6483\u3092\u5148\u306B\u5438\u53CE\uFF09\nDIS\uFF08\u7D2B\uFF09\uFF1A\u76F8\u624B\u306E\u884C\u3092\u30E9\u30F3\u30C0\u30E0\u306B\u30ED\u30C3\u30AF\uFF08\u6B21\u306EAssign\u304B\u3089\u914D\u7F6E\u30FB\u767A\u52D5\u4E0D\u53EF\uFF09\n\n\u3010\u884C\u3054\u3068\u306E\u52B9\u679C\u91CF\u3011\n1\u884C\u76EE\uFF081\u67A0\uFF09\uFF1AATK
    2 / DEF 1 / DIS 1\u884C\u30ED\u30C3\u30AF\n2\u884C\u76EE\uFF082\u67A0\uFF09\uFF1AATK
    3 / DEF 2 / DIS 2\u884C\u30ED\u30C3\u30AF\n3\u884C\u76EE\uFF083\u67A0\uFF09\uFF1AATK
    5 / DEF 3 / DIS 3\u884C\u30ED\u30C3\u30AF\n4\u884C\u76EE\uFF084\u67A0\uFF09\uFF1AATK
    8 / DEF 4 / DIS 4\u884C\u30ED\u30C3\u30AF\n5\u884C\u76EE\uFF085\u67A0\uFF09\uFF1AATK
    12 / DEF 6 / DIS 5\u884C\u30ED\u30C3\u30AF\n\n\u3010\u30B7\u30FC\u30EB\u30C9\u306E\u4ED5\u69D8\u3011\n\u30FB\u653B\u6483\u3092\u53D7\u3051\u305F\u3068\u304D\u30B7\u30FC\u30EB\u30C9\u304C\u5148\u306B\u524A\u3089\u308C\u308B\n\u30FBResolve\u7D42\u4E86\u5F8C\u306B\u30B7\u30FC\u30EB\u30C9\u306F\u534A\u6E1B\uFF08\u5207\u308A\u6368\u3066\uFF09\n\n\u3010\u7279\u6B8A\u30EB\u30FC\u30EB\u3011\n\u30B8\u30E3\u30B9\u30C8\u30AC\u30FC\u30C9\uFF1AATK\u3068DEF\u304C\u540C\u3058\u884C\u3067\u540C\u6642\u767A\u52D5
    \u2192 ATK\u3092\u7121\u52B9\u5316\u3057\u653B\u6483\u5074\u306B2\u500D\u53CD\u5C04\nATK\u30B3\u30F3\u30DC\uFF1A\u540C\u30BF\u30FC\u30F3\u306BATK\u884C\u30922\u3064\u4EE5\u4E0A\u5B8C\u6210
    \u2192 \u5B8C\u6210\u6570\u5206\u306E\u8FFD\u52A0\u30C0\u30E1\u30FC\u30B8\n\n\u3010DIS\u306E\u8A73\u7D30\u3011\n\u30FB\u30ED\u30C3\u30AF\u4E2D\u306E\u884C\u306FX\u30DE\u30FC\u30AF\u3067\u8868\u793A\n\u30FB\u5B8C\u6210\u6E08\u307F\u306E\u884C\u3082\u30ED\u30C3\u30AF\u5BFE\u8C61\u3002\u305D\u306E\u5834\u5408\u306F\u305D\u306E\u30BF\u30FC\u30F3\u306F\u901A\u5E38\u767A\u52D5\u3057\u3001\u6B21\u306EAssign\u304B\u3089\u30ED\u30C3\u30AF\n\n\u3010\u5148\u624B\u9806\u3011\n\u521D\u56DE\u306F\u30E9\u30F3\u30C0\u30E0\u3002\u4EE5\u964D\u306F\u6BCE\u30BF\u30FC\u30F3\u4EA4\u4E92\u306B\u5148\u624B\u304C\u5165\u308C\u66FF\u308F\u308B"
